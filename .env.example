# Ezokhetho Environment Variables
# Copy this file to .env.local and fill in your real values

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.ezokhetho.com

# ─────────────────────────────────────────────
# PayFast — South African Payment Gateway
# Get your keys at: https://www.payfast.co.za/
# Dashboard → My Account → Merchant Details
# ─────────────────────────────────────────────

# Set to "true" while testing (uses sandbox.payfast.co.za)
PAYFAST_SANDBOX=true

# Your PayFast Merchant ID (found in your PayFast dashboard)
PAYFAST_MERCHANT_ID=your_merchant_id_here

# Your PayFast Merchant Key (found in your PayFast dashboard)
PAYFAST_MERCHANT_KEY=your_merchant_key_here

# Optional: Passphrase you set in your PayFast account settings
# (improves security of signature verification)
PAYFAST_PASSPHRASE=your_passphrase_here
